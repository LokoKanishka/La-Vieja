# Core ports
N8N_PORT=5111
POSTGRES_PORT=5433
STRATEGY_PORT=8100

# Paths
WORKSPACE_PATH=/home/lucy/Escritorio/La Vieja

# Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

# n8n
N8N_ENCRYPTION_KEY=replace-with-long-random-key
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# Strategy service
TRADING_MODE=paper
FEATURE_SET_VERSION=v1
PAPER_EQUITY_USD=10000
MAX_POSITION_PCT=0.20
MAX_ORDERS_PER_HOUR=12
DAILY_LOSS_LIMIT_USD=300
GLOBAL_KILL_SWITCH_DEFAULT=false
MONITORED_SYMBOL=BTCUSD
MONITORED_TIMEFRAME=5m
MARKET_DATA_STALE_MINUTES=15
FEATURES_DATA_STALE_MINUTES=30
RECONCILE_STALE_MINUTES=3
REJECTED_ORDERS_1H_WARN_THRESHOLD=3
ALERT_COOLDOWN_MINUTES=30
RECONCILE_HEARTBEAT_INTERVAL_MINUTES=1
PAPER_GO_NO_GO_LOOKBACK_DAYS=14
GO_NO_GO_MIN_DAYS=14
GO_NO_GO_MIN_EXECUTED_ORDERS=20
GO_NO_GO_MIN_WIN_RATE=0.45
GO_NO_GO_MAX_DRAWDOWN_PCT=0.08
GO_NO_GO_MIN_REALIZED_PNL_USD=0
GO_NO_GO_MAX_REJECTION_RATE=0.30
GO_NO_GO_MIN_RECONCILE_UPTIME_PCT=95
GO_NO_GO_MAX_CRITICAL_ALERTS_24H=0
FORECAST_DEFAULT_HORIZON_MINUTES=10
FORECAST_MIN_MOVE_BPS=5
FORECAST_MAX_RESOLUTION_LAG_MINUTES=20
FORECAST_GO_MIN_ACCURACY=0.55
TAKER_FEE_BPS=10
VOLATILITY_CUTOFF=0.08

# Exchange adapter (live)
EXCHANGE_ADAPTER=paper
EXCHANGE_ID=kraken
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=
EXCHANGE_SYMBOL=BTC/USD
LIVE_ORDER_TYPE=market
EXCHANGE_SANDBOX=false

# Electrum RPC (optional)
ENABLE_ELECTRUM_RPC=false
ELECTRUM_RPC_URL=http://127.0.0.1:7777
ELECTRUM_RPC_USER=
ELECTRUM_RPC_PASSWORD=

# Zero-cost AI keys (must stay empty in this machine)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
